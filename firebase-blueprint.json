{
  "entities": {
    "Worker": {
      "title": "Worker",
      "description": "Information about a company worker.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "qrCode": { "type": "string" },
        "active": { "type": "boolean" },
        "pin": { "type": "string" },
        "dni": { "type": "string" },
        "phone": { "type": "string" },
        "defaultMode": { "type": "string", "enum": ["HORAS", "DESTAJO"] }
      },
      "required": ["id", "name", "active", "phone"]
    },
    "Site": {
      "title": "Site",
      "description": "Job site or construction project location.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "address": { "type": "string" },
        "active": { "type": "boolean" },
        "coordinates": {
          "type": "object",
          "properties": {
            "latitude": { "type": "number" },
            "longitude": { "type": "number" }
          }
        }
      },
      "required": ["id", "name", "active"]
    },
    "WorkLog": {
      "title": "WorkLog",
      "description": "A record of a worker action at a site.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "workerId": { "type": "string" },
        "workerName": { "type": "string" },
        "siteId": { "type": "string" },
        "siteName": { "type": "string" },
        "type": { "type": "string", "enum": ["ENTRADA", "SALIDA", "INICIO_DESCANSO", "FIN_DESCANSO", "REGISTRO"] },
        "timestamp": { "type": "number" },
        "dateStr": { "type": "string" },
        "timeStr": { "type": "string" },
        "location": {
          "type": "object",
          "properties": {
            "latitude": { "type": "number" },
            "longitude": { "type": "number" },
            "accuracy": { "type": "number" },
            "address": { "type": "string" }
          }
        },
        "distanceMeters": { "type": "number" },
        "locationWarning": { "type": "boolean" },
        "workReport": { "type": "string" },
        "workMode": { "type": "string", "enum": ["HORAS", "DESTAJO"] }
      },
      "required": ["id", "workerId", "siteId", "type", "timestamp"]
    },
    "AdminUser": {
      "title": "AdminUser",
      "description": "Administrator account for the platform.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "username": { "type": "string" },
        "password": { "type": "string" },
        "active": { "type": "boolean" },
        "createdAt": { "type": "number" }
      },
      "required": ["id", "username", "password", "active"]
    },
    "ToolRecord": {
      "title": "ToolRecord",
      "description": "A record of a tool owned or used by a worker.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "workerId": { "type": "string" },
        "workerName": { "type": "string" },
        "toolName": { "type": "string" },
        "brand": { "type": "string" },
        "model": { "type": "string" },
        "timestamp": { "type": "number" },
        "dateStr": { "type": "string" },
        "timeStr": { "type": "string" }
      },
      "required": ["id", "workerId", "toolName", "brand"]
    },
    "AppConfig": {
      "title": "AppConfig",
      "description": "Global application configuration.",
      "type": "object",
      "properties": {
        "adminPhone": { "type": "string" },
        "googleSheetUrl": { "type": "string" },
        "adminPassword": { "type": "string" },
        "logoUrl": { "type": "string" },
        "logoScaleLogin": { "type": "number" },
        "logoScaleDashboard": { "type": "number" }
      }
    }
  },
  "firestore": {
    "workers": {
      "schema": "Worker",
      "description": "Directory of workers."
    },
    "sites": {
      "schema": "Site",
      "description": "List of available job sites."
    },
    "logs": {
      "schema": "WorkLog",
      "description": "Chronological records of work actions."
    },
    "admins": {
      "schema": "AdminUser",
      "description": "Admin access accounts."
    },
    "tools": {
      "schema": "ToolRecord",
      "description": "Worker equipment records."
    },
    "config": {
      "schema": "AppConfig",
      "description": "Global settings for the application."
    }
  }
}
