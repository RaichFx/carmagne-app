rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }
    
    // For this prototype, we don't have standard Auth Claims yet.
    // We assume an admin is someone who knows the admin password in config.
    // In a real app, we'd use Custom Claims or an 'admins' collection check.
    function isAdmin() {
      // Temporary: Allow if authenticated (for setup) or restrict via specific UIDs if known.
      // Since no auth is fully implemented for workers, we'll allow reads to everything 
      // but restrict writes to validated schemas.
      return true; // DANGEROUS: For initial setup only.
    }

    // --- Entitie Validations ---

    function isValidWorker(data) {
      return data.keys().hasAll(['id', 'name', 'active', 'phone']) &&
             data.id is string && data.id.size() <= 50 &&
             data.name is string && data.name.size() <= 100 &&
             data.phone is string && data.phone.size() <= 20 &&
             data.active is bool;
    }

    function isValidLog(data) {
      return data.keys().hasAll(['id', 'workerId', 'siteId', 'type', 'timestamp']) &&
             data.id is string && data.id.size() <= 50 &&
             data.workerId is string && data.workerId.size() <= 50 &&
             data.siteId is string && data.siteId.size() <= 50 &&
             data.type in ['ENTRADA', 'SALIDA', 'INICIO_DESCANSO', 'FIN_DESCANSO', 'REGISTRO'] &&
             data.timestamp is int;
    }

    function isValidTool(data) {
      return data.keys().hasAll(['id', 'workerId', 'toolName', 'brand']) &&
             data.id is string && data.id.size() <= 50 &&
             data.workerId is string &&
             data.toolName is string && data.toolName.size() <= 100 &&
             data.brand is string && data.brand.size() <= 50;
    }

    // --- Collection Rules ---

    match /workers/{workerId} {
      allow read: if true; // Workers need to find themselves
      allow create: if isValidId(workerId) && isValidWorker(incoming());
      allow update: if isValidId(workerId) && isValidWorker(incoming()) && (
        // Only allow updating non-identifying fields or admin updates
        incoming().id == existing().id
      );
      allow delete: if true; // Admin functionality
    }

    match /sites/{siteId} {
      allow read: if true;
      allow write: if isValidId(siteId);
    }

    match /logs/{logId} {
      allow read: if true;
      allow create: if isValidId(logId) && isValidLog(incoming());
      allow update: if isValidId(logId) && isValidLog(incoming()) && (
        incoming().timestamp == existing().timestamp // Immutable timestamp
      );
      allow delete: if true; 
    }

    match /admins/{adminId} {
      allow read: if true;
      allow write: if isValidId(adminId);
    }

    match /tools/{toolId} {
      allow read: if true;
      allow create: if isValidId(toolId) && isValidTool(incoming());
      allow delete: if true;
    }

    match /config/{configId} {
      allow read: if true;
      allow write: if true; // Admin functionality
    }
  }
}
